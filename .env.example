# DOSYATRANS - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve düzenleyin

# ═══════════════════════════════════════════════════════════════
# SUNUCU AYARLARI
# ═══════════════════════════════════════════════════════════════

# Sunucu portu (varsayılan: 3001)
PORT=3001

# ═══════════════════════════════════════════════════════════════
# GÜVENLIK AYARLARI
# ═══════════════════════════════════════════════════════════════

# Kimlik doğrulama token'ı
# ÖNEMLİ: Bu değeri değiştirin!
AUTH_TOKEN=benim-gizli-tokenum-buraya-yazin

# ═══════════════════════════════════════════════════════════════
# ERİŞİM KISITLAMALARI
# ═══════════════════════════════════════════════════════════════

# İzin verilen yollar (noktalı virgül ile ayırın)
# Boş bırakılırsa tüm yollar erişilebilir
# Windows örneği: ALLOWED_PATHS=C:\Projects;D:\Work
# Linux/macOS örneği: ALLOWED_PATHS=/home/user/projects;/var/www
ALLOWED_PATHS=

# Engellenen yollar (noktalı virgül ile ayırın)
# Windows örneği: BLOCKED_PATHS=C:\Windows;C:\System
# Linux/macOS örneği: BLOCKED_PATHS=/etc;/root
BLOCKED_PATHS=

# ═══════════════════════════════════════════════════════════════
# DOSYA AYARLARI
# ═══════════════════════════════════════════════════════════════

# Maksimum dosya okuma boyutu (bytes)
# Varsayılan: 10485760 (10MB)
MAX_FILE_SIZE=10485760
