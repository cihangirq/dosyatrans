# DOSYATRANS v3.0 - Ortam Degiskenleri
# Bu dosyayi .env olarak kopyalayin ve duzenleyin

# ═══════════════════════════════════════════════════════════════
# SUNUCU AYARLARI
# ═══════════════════════════════════════════════════════════════

# Sunucu portu (varsayilan: 3001)
PORT=3001

# ═══════════════════════════════════════════════════════════════
# GUVENLIK AYARLARI
# ═══════════════════════════════════════════════════════════════

# Kimlik dogrulama token'i
# ONEMLI: Bu degeri degistirin!
AUTH_TOKEN=benim-gizli-tokenum-buraya-yazin

# ═══════════════════════════════════════════════════════════════
# ERISIM KISITLAMALARI
# ═══════════════════════════════════════════════════════════════

# Izin verilen yollar (noktali virgul ile ayirin)
# Bos birakilirsa tum yollar erisilebilir
# Windows ornegi: ALLOWED_PATHS=C:\Projects;D:\Work
# Linux/macOS ornegi: ALLOWED_PATHS=/home/user/projects;/var/www
ALLOWED_PATHS=

# Engellenen yollar (noktali virgul ile ayirin)
# Windows ornegi: BLOCKED_PATHS=C:\Windows;C:\System
# Linux/macOS ornegi: BLOCKED_PATHS=/etc;/root
BLOCKED_PATHS=

# ═══════════════════════════════════════════════════════════════
# DOSYA AYARLARI
# ═══════════════════════════════════════════════════════════════

# Maksimum dosya okuma boyutu (bytes)
# Varsayilan: 10485760 (10MB)
MAX_FILE_SIZE=10485760

# ═══════════════════════════════════════════════════════════════
# TUNNEL AYARLARI
# ═══════════════════════════════════════════════════════════════

# Cloudflared otomatik baslatma
# Varsayilan: true (baslat.bat ile otomatik baslar)
# false yaparsaniz manuel olarak baslatmaniz gerekir
AUTO_START_CLOUDFLARED=true
